# Environment Variables Example

# Backend Environment Variables
# The URL of the Postgres database (e.g., provided by Railway Postgres plugin)
DATABASE_URL="postgresql://user:password@localhost:5432/ethara?schema=public"

# The port the Express server will run on (default 3001)
PORT=3001

# The URL of the frontend in development (not needed in production as it is served by Express)
FRONTEND_URL="http://localhost:5173"

# JWT Secrets - MUST BE CHANGED IN PRODUCTION
ACCESS_TOKEN_SECRET="your-super-secret-access-token-key"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-token-key"

# Node Environment ('development' or 'production')
NODE_ENV="development"

# Frontend Environment Variables (must start with VITE_)
# The URL of the API. Localhost for dev, empty/relative for production
VITE_API_URL="http://localhost:3001/api"
